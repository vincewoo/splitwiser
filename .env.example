# Splitwiser Environment Variables Example
# Copy this file to .env and fill in your values

# Database (automatically created if using SQLite)
# DATABASE_URL=sqlite:///./db.sqlite3

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Brevo Email API (for password reset, email verification, etc.)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Splitwiser

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# LLM Receipt Scanning (pick one provider)
# LLM_PROVIDER=openai          # "openai" (default) or "gemini"
# OPENAI_API_KEY=sk-your-key   # Required if using OpenAI (default)
# GEMINI_API_KEY=your-key       # Required if using Gemini
